    {
      "id": 2,
      "type": "multi_choice",
      "title": "The Division Symbol",
      "background": "temple_interior",
      "coins": 20,
      "mechanic_reason": "Age 8 medium: multi_choice introduces the ÷ symbol explicitly and connects it to equal sharing from stage 1",
      "success_message": "Yes! The ÷ symbol means 'divide into equal groups'!",
      "rounds": [
        {
          "instruction": "This is the division symbol: ÷. What does 8 ÷ 2 mean?",
          "options": [
            {
              "id": "a",
              "text": "Take 2 away from 8",
              "correct": false
            },
            {
              "id": "b",
              "text": "Split 8 into 2 equal groups",
              "correct": true
            },
            {
              "id": "c",
              "text": "Add 8 and 2 together",
              "correct": false
            }
          ]
        },
        {
          "instruction": "If we see 10 ÷ 5, what are we doing?",
          "options": [
            {
              "id": "a",
              "text": "Making 5 groups with equal items",
              "correct": true
            },
            {
              "id": "b",
              "text": "Counting to 10 five times",
              "correct": false
            },
            {
              "id": "c",
              "text": "Subtracting 5 from 10",
              "correct": false
            }
          ]
        },
        {
          "instruction": "12 ÷ 3 = ? means we put 12 things into how many groups?",
          "options": [
            {
              "id": "a",
              "text": "12 groups",
              "correct": false
            },
            {
              "id": "b",
              "text": "3 groups",
              "correct": true
            },
            {
              "id": "c",
              "text": "9 groups",
              "correct": false
            }
          ]
        },
        {
          "instruction": "The Samurai Monkey says 6 ÷ 2 = 4 because 6 - 2 = 4. Is he right?",
          "options": [
            {
              "id": "a",
              "text": "Yes, division is the same as subtraction",
              "correct": false
            },
            {
              "id": "b",
              "text": "No! 6 ÷ 2 = 3 (3 in each group)",
              "correct": true
            },
            {
              "id": "c",
              "text": "Yes, 6 ÷ 2 = 4",
              "correct": false
            }
          ]
        },
        {
          "instruction": "Which picture shows 15 ÷ 3?",
          "options": [
            {
              "id": "a",
              "text": "15 cherries in 5 piles of 3",
              "correct": false
            },
            {
              "id": "b",
              "text": "15 cherries in 3 piles of 5",
              "correct": true
            },
            {
              "id": "c",
              "text": "12 cherries in 3 piles of 4",
              "correct": false
            }
          ]
        }
      ],
      "round_bonus_coins": 2
