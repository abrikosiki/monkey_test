OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Один проект Supabase с приложением «пробник» — те же URL и ключ, что у игры.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ANON_KEY=   # можно вместо service role только для чтения (если политики RLS позволяют)

# Таблица профилей детей (как в SQL: public.children).
SUPABASE_CHILDREN_TABLE=children

# Колонка для поиска по коду из поля тьютора (MONKEY-xxxx).
# Новая схема Monkey Game: code. Старая: child_code.
SUPABASE_CHILD_LOOKUP_COLUMN=code
